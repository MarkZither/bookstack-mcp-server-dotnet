# Copy this file to .env and fill in your values before running docker compose
# cp .env.example .env

# Required — BookStack connection
BOOKSTACK_BASE_URL=https://your-bookstack.example.com/
BOOKSTACK_TOKEN_SECRET=your-token-id:your-token-secret

# Recommended — HTTP transport auth token (use a long random string)
BOOKSTACK_MCP_HTTP_AUTH_TOKEN=change-me-to-a-long-random-string

# Required only for docker-compose.postgres.yml
POSTGRES_PASSWORD=change-me
# POSTGRES_USER=bookstack   # optional, defaults to bookstack

# Required only for docker-compose.postgres-external.yml
# VECTOR_DB_CONNECTION_STRING=Host=db.example.com;Port=5432;Database=bookstack_vectors;Username=bookstack;Password=secret
