# ─── BookStack API ────────────────────────────────────────────────────────────
# URL BookStack is reachable at FROM the MCP server container.
# When running via docker-compose.dev.yml (full Compose stack), keep the default below.
# When running the MCP server natively with F5 / launch.json, this is overridden
# automatically to http://localhost:6875 — you do not need to change it here.
BOOKSTACK_BASE_URL=http://bookstack:6875

# API token — generated in the BookStack UI after first-run setup:
#   1. Open http://localhost:6875 and log in
#   2. Click your avatar (top-right) → Edit Profile → API Tokens → Add Token
#   3. Copy the Token ID and Token Secret into the values below
BOOKSTACK_TOKEN_ID=replace-me
BOOKSTACK_TOKEN_SECRET=replace-me

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Bearer token that protects the /mcp and /health HTTP endpoints.
# Replace this with any random string. It is not publicly exposed but must not
# be committed to version control.
BOOKSTACK_MCP_HTTP_AUTH_TOKEN=dev-token-replace-me

# Port the MCP server listens on (also mapped to the host).
# Defaults to 3001 to avoid collision with production Compose files that use 3000.
BOOKSTACK_MCP_HTTP_PORT=3001

# Admin sidecar port (used by the VS Code extension). Set to 0 to disable it
# during local development to avoid port conflicts when the extension isn't running.
BOOKSTACK_ADMIN_PORT=0

# ─── MariaDB ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=dev-root-password
DB_DATABASE=bookstack
DB_USERNAME=bookstack
DB_PASSWORD=bookstack-dev-password

# ─── BookStack Application ────────────────────────────────────────────────────
# Public URL BookStack uses when generating internal links.
# Must match the URL you open in your browser.
APP_URL=http://localhost:6875

# Laravel application key — required on first run. Generate one with:
#   docker run --rm --entrypoint /bin/bash lscr.io/linuxserver/bookstack:latest appkey
APP_KEY=replace-me

# ─── Ollama ───────────────────────────────────────────────────────────────────
# When using the embedded Ollama container (--profile ollama):
#   OLLAMA_BASE_URL=http://ollama:11434
#
# When using Ollama running on the Windows host from WSL2
# (Ollama configured to listen on 0.0.0.0:11434):
#   OLLAMA_BASE_URL=http://host-gateway:11434
#
OLLAMA_BASE_URL=http://ollama:11434

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Enable semantic / vector search. Requires Ollama and a compatible database provider.
VECTOR_SEARCH_ENABLED=false
