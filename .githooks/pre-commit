#!/bin/sh
# Pre-commit hook: enforce dotnet format
# Runs 'dotnet format --verify-no-changes' and blocks the commit if formatting
# issues are found. Run 'dotnet format' to fix them, then re-stage and commit.

echo "Running dotnet format --verify-no-changes..."
dotnet format --verify-no-changes
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "Commit blocked: formatting issues detected."
  echo "Run 'dotnet format' to fix them, re-stage the changes, then commit again."
  exit 1
fi

exit 0
